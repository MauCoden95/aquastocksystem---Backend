// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Supplier {
  id          Int        @id @default(autoincrement())
  name        String
  phone       String?
  email       String?
  cuit        String?    // taxId
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt @default(now())
  deletedAt   DateTime?
  createdById Int?
  updatedById Int?
  createdBy   User?      @relation(name: "CreatedSuppliers", fields: [createdById], references: [id])
  updatedBy   User?      @relation(name: "UpdatedSuppliers", fields: [updatedById], references: [id])
  purchases   Purchase[]

  @@map("suppliers")
}

model Category {
  id          Int       @id @default(autoincrement())
  name        String
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  createdById Int?
  updatedById Int?
  createdBy   User?     @relation(name: "CreatedCategories", fields: [createdById], references: [id])
  updatedBy   User?     @relation(name: "UpdatedCategories", fields: [updatedById], references: [id])
  products    Product[]

  @@map("categories")
}

model Brand {
  id          Int       @id @default(autoincrement())
  name        String
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  createdById Int?
  updatedById Int?
  createdBy   User?     @relation(name: "CreatedBrands", fields: [createdById], references: [id])
  updatedBy   User?     @relation(name: "UpdatedBrands", fields: [updatedById], references: [id])
  products    Product[]

  @@map("brands")
}

model Product {
  id             Int             @id @default(autoincrement())
  name           String
  description    String?
  categoryId     Int
  brandId        Int
  barcode        String?
  purchasePrice  Decimal         @db.Decimal(10, 2)
  sellingPrice   Decimal         @db.Decimal(10, 2)
  minStock       Int             @default(0)
  stock          Int             @default(0)
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deletedAt      DateTime?
  createdById    Int?
  updatedById    Int?
  category       Category        @relation(fields: [categoryId], references: [id])
  brand          Brand           @relation(fields: [brandId], references: [id])
  createdBy      User?           @relation(name: "CreatedProducts", fields: [createdById], references: [id])
  updatedBy      User?           @relation(name: "UpdatedProducts", fields: [updatedById], references: [id])
  purchaseItems  PurchaseItem[]
  saleItems      SaleItem[]
  stockMovements StockMovement[]

  @@map("products")
}

model Purchase {
  id            Int            @id @default(autoincrement())
  supplierId    Int
  date          DateTime       @default(now())
  total         Decimal        @db.Decimal(10, 2)
  status        String
  supplier      Supplier       @relation(fields: [supplierId], references: [id])
  purchaseItems PurchaseItem[]

  @@map("purchases")
}

model PurchaseItem {
  id            Int      @id @default(autoincrement())
  purchaseId    Int
  productId     Int
  quantity      Int
  unitPrice     Decimal  @db.Decimal(10, 2)
  subtotal      Decimal  @db.Decimal(10, 2)
  purchase      Purchase @relation(fields: [purchaseId], references: [id])
  product       Product  @relation(fields: [productId], references: [id])

  @@map("purchase_items")
}

model Client {
  id           Int       @id @default(autoincrement())
  name         String
  taxId        String?   // cuit
  phone        String?
  email        String?
  address      String?
  creditLimit  Decimal   @db.Decimal(10, 2) @default(0)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  createdById  Int?
  updatedById  Int?
  createdBy    User?     @relation(name: "CreatedClients", fields: [createdById], references: [id])
  updatedBy    User?     @relation(name: "UpdatedClients", fields: [updatedById], references: [id])
  sales        Sale[]
  payments     Payment[]

  @@map("clients")
}

model Sale {
  id               Int        @id @default(autoincrement())
  clientId         Int
  date             DateTime   @default(now())
  total            Decimal    @db.Decimal(10, 2)
  status           String
  paymentMethod    String
  cancellationDate String?
  cancellationTime String?
  cancelledByName  String?
  client           Client     @relation(fields: [clientId], references: [id])
  saleItems        SaleItem[]

  @@map("sales")
}

model SaleItem {
  id            Int      @id @default(autoincrement())
  saleId        Int
  productId     Int
  quantity      Int
  unitPrice     Decimal  @db.Decimal(10, 2)
  subtotal      Decimal  @db.Decimal(10, 2)
  sale          Sale     @relation(fields: [saleId], references: [id])
  product       Product  @relation(fields: [productId], references: [id])

  @@map("sale_items")
}

model Payment {
  id            Int      @id @default(autoincrement())
  clientId      Int
  date          DateTime @default(now())
  amount        Decimal  @db.Decimal(10, 2)
  paymentMethod String
  status        String   @default("PAID")
  cancelReason  String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt @default(now())
  deletedAt     DateTime?
  cancelledAt   DateTime?
  createdById   Int?
  updatedById   Int?
  cancelledById Int?
  
  client        Client   @relation(fields: [clientId], references: [id])
  createdBy     User?    @relation(name: "CreatedPayments", fields: [createdById], references: [id])
  updatedBy     User?    @relation(name: "UpdatedPayments", fields: [updatedById], references: [id])
  cancelledBy   User?    @relation(name: "CancelledPayments", fields: [cancelledById], references: [id])

  @@map("payments")
}

model User {
  id                Int        @id @default(autoincrement())
  name              String
  email             String     @unique
  password          String
  role              String
  isActive          Boolean    @default(true)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  deletedAt         DateTime?
  createdProducts   Product[]  @relation("CreatedProducts")
  updatedProducts   Product[]  @relation("UpdatedProducts")
  createdBrands     Brand[]    @relation("CreatedBrands")
  updatedBrands     Brand[]    @relation("UpdatedBrands")
  createdCategories Category[] @relation("CreatedCategories")
  updatedCategories Category[] @relation("UpdatedCategories")
  createdSuppliers  Supplier[] @relation("CreatedSuppliers")
  updatedSuppliers  Supplier[] @relation("UpdatedSuppliers")
  createdClients    Client[]   @relation("CreatedClients")
  updatedClients    Client[]   @relation("UpdatedClients")
  createdPayments   Payment[]  @relation("CreatedPayments")
  updatedPayments   Payment[]  @relation("UpdatedPayments")
  cancelledPayments Payment[]  @relation("CancelledPayments")

  @@map("users")
}

model StockMovement {
  id           Int      @id @default(autoincrement())
  productId    Int
  movementType String
  quantity     Int
  date         DateTime @default(now())
  product      Product  @relation(fields: [productId], references: [id])

  @@map("stock_movements")
}
